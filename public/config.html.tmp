                                <button type="button" class="btn-tool" onclick="document.getElementById('bgStatus').innerText = 'none';" style="padding: 0 10px; height: 32px; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; background: rgba(255,255,255,0.02); color: #ef4444; font-size: 11px; cursor: pointer; white-space: nowrap;">Clear</button>
