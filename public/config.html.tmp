<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ScribbleBooth | Executive Configurator</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Inter:wght@300;400;500&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0a0a0b;
            --card-bg: rgba(255, 255, 255, 0.03);
            --accent: #D3BB7C;
            --accent-glow: rgba(211, 187, 124, 0.3);
            --border: rgba(255, 255, 255, 0.08);
            --text-muted: #a0a0a0;
            --sidebar-width: 260px;
        }

        * {
            box-sizing: border-box;
            scrollbar-width: thin;
            scrollbar-color: var(--accent) transparent;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-dark);
            background-image:
                radial-gradient(circle at 0% 0%, rgba(211, 187, 124, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 100% 100%, rgba(211, 187, 124, 0.05) 0%, transparent 40%);
            color: #fff;
            margin: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-width);
            background: rgba(0, 0, 0, 0.4);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 30px 0;
            backdrop-filter: blur(10px);
            overflow-y: auto;
        }

        .logo-area {
            padding: 0 30px 40px 30px;
            font-family: 'Outfit', sans-serif;
        }

        .logo-area h1 {
            font-size: 22px;
            margin: 0;
            background: linear-gradient(to right, #fff, var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
        }

        .logo-area span {
            font-size: 11px;
            color: var(--text-muted);
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .nav-item {
            padding: 14px 30px;
            color: var(--text-muted);
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            border-left: 3px solid transparent;
        }

        .nav-item:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.02);
        }

        .nav-item.active {
            color: var(--accent);
            background: rgba(211, 187, 124, 0.05);
            border-left-color: var(--accent);
            font-weight: 600;
        }

        .nav-divider {
            font-size: 10px;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: 15px 30px 5px 30px;
            letter-spacing: 1.5px;
            font-weight: 700;
        }

        .nav-line {
            height: 1px;
            background: rgba(255,255,255,0.08);
            margin: 10px 30px;
        }

        /* MAIN CONTENT */
        .main-view {
            flex: 1;
            padding: 40px 60px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .view-section {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .view-section.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h2 {
            font-family: 'Outfit', sans-serif;
            font-size: 28px;
            margin: 0 0 30px 0;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 30px;
            margin-bottom: 25px;
            backdrop-filter: blur(5px);
        }

        .input-group {
            margin-bottom: 25px;
        }

        .input-group label {
            display: block;
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
            font-weight: 600;
        }

        input[type="text"],
        input[type="number"],
        textarea,
        select {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 12px 15px;
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            outline: none;
            transition: 0.3s;
        }

        select option {
            background-color: #121214;
            color: #fff;
        }

        input:focus,
        textarea:focus,
        select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 15px var(--accent-glow);
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 20px;
        }

        /* COLOR PICKER CUSTOM */
        .color-row {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 10px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 10px;
            border: 1px solid var(--border);
        }

        input[type="color"] {
            -webkit-appearance: none;
            width: 40px;
            height: 40px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            background: none;
        }

        input[type="color"]::-webkit-color-swatch {
            border-radius: 6px;
            border: 2px solid rgba(255, 255, 255, 0.1);
        }

        /* THEME PRESETS */
        .preset-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 15px;
        }

        .preset-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 15px;
            cursor: pointer;
            transition: 0.3s;
            text-align: center;
        }

        .preset-card:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: var(--accent);
            transform: translateY(-3px);
        }

        .preset-card.active {
            border-color: var(--accent);
            background: var(--accent-glow);
        }

        .preset-icon {
            font-size: 24px;
            margin-bottom: 10px;
            display: block;
        }

        /* BUTTONS */
        .save-bar {
            position: fixed;
            bottom: 40px;
            right: 60px;
            z-index: 100;
        }

        .btn-primary {
            background: var(--accent);
            color: #000;
            border: none;
            padding: 16px 40px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            box-shadow: 0 10px 30px var(--accent-glow);
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .btn-primary:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 40px var(--accent-glow);
        }

        /* TOGGLE */
        .switch {
            position: relative;
            display: inline-block;
            width: 44px;
            height: 24px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #333;
            transition: .4s;
            border-radius: 24px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked+.slider {
            background-color: var(--accent);
        }

        input:checked+.slider:before {
            transform: translateX(20px);
        }

        .form-row-between {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .success-toast {
            position: fixed;
            top: 30px;
            right: 30px;
            background: #047857;
            color: white;
            padding: 12px 25px;
            border-radius: 10px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
            display: none;
            animation: slideIn 0.4s ease;
            z-index: 1000;
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .upload-box {
            border: 2px dashed var(--border);
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            transition: 0.3s;
            background: rgba(255, 255, 255, 0.01);
        }

        .upload-box:hover {
            border-color: var(--accent);
            background: rgba(255, 255, 255, 0.03);
        }

        .preview-img {
            max-height: 80px;
            margin-bottom: 10px;
            border-radius: 5px;
            border: 1px solid var(--border);
        }

        /* RADIO BUTTONS */
        .radio-group {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .radio-item {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }

        .radio-item input[type="radio"] {
            width: 18px;
            height: 18px;
            accent-color: var(--accent);
            cursor: pointer;
        }

        .radio-item label {
            margin: 0 !important;
            text-transform: none !important;
            font-size: 14px !important;
            color: #fff !important;
            cursor: pointer;
        }

        /* ASSET LIBRARY MODAL */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }

        .modal-content {
            background: #151518;
            border: 1px solid var(--border);
            border-radius: 20px;
            width: 100%;
            max-width: 900px;
            max-height: 85vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        .modal-header {
            padding: 20px 30px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            margin: 0;
            font-size: 18px;
            font-family: 'Outfit', sans-serif;
        }

        .btn-close {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 24px;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-close:hover {
            color: #fff;
        }

        .asset-grid {
            flex: 1;
            overflow-y: auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 20px;
            padding: 30px;
        }

        .asset-item {
            position: relative;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            aspect-ratio: 1;
            cursor: pointer;
            transition: 0.3s;
        }

        .asset-item:hover {
            border-color: var(--accent);
            transform: translateY(-3px);
            background: rgba(255, 255, 255, 0.05);
        }

        .asset-item img,
        .asset-item video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .asset-item .delete-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            width: 28px;
            height: 28px;
            background: rgba(255, 0, 0, 0.7);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            opacity: 0;
            transition: 0.3s;
        }

        .asset-item:hover .delete-btn {
            opacity: 1;
        }

        .asset-item .delete-btn:hover {
            background: #ff0000;
            transform: scale(1.1);
        }

        .asset-name {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.6);
            padding: 5px;
            font-size: 9px;
            text-align: center;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .btn-browse {
            font-size: 10px;
            background: rgba(211, 187, 124, 0.1);
            color: var(--accent);
            border: 1px solid var(--accent);
            padding: 4px 10px;
            border-radius: 4px;
            cursor: pointer;
            margin-top: 5px;
            display: inline-block;
            transition: 0.3s;
        }

        .btn-browse:hover {
            background: var(--accent);
            color: #000;
        }

        /* Side-by-side input and color picker */
        .input-with-color {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .input-with-color .text-control {
            flex: 1;
        }

        .input-with-color .color-control {
            flex-shrink: 0;
        }

        /* Text formatting toolbar */
        .text-toolbar {
            display: flex;
            gap: 4px;
            margin-bottom: 6px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 6px;
            padding: 3px;
            width: fit-content;
        }

        .btn-tool {
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.6);
            padding: 4px 8px;
            font-size: 11px;
            font-family: inherit;
            cursor: pointer;
            border-radius: 4px;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 26px;
            height: 26px;
        }

        .btn-tool:hover {
            background: rgba(255, 255, 255, 0.1);
            color: var(--accent);
        }

        .btn-tool b {
            font-weight: 800;
        }

        .btn-tool i {
            font-style: italic;
        }

        .btn-tool u {
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div class="sidebar">
        <div class="logo-area">
            <h1>ScribbleBooth</h1>
            <span>Config Suite 1.0</span>
        </div>
        <a href="/dashboard.html" style="display: block; margin: 0 15px 15px; background: rgba(255,255,255,0.1); color: white; text-align: center; padding: 10px; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500;">⬅️ Back to Dashboard</a>

        <div class="nav-item active" onclick="showSection('visuals')">🎨 Visual Theme</div>

        <div class="nav-divider">✍️ Edit Per Screen</div>
        <div class="nav-item" onclick="showSection('content-idle')">🖥️ State Idle</div>
        <div class="nav-item" onclick="showSection('content-form')">📝 State Form</div>
        <div class="nav-item" onclick="showSection('content-ready-video')">🎬 State Ready Video</div>
        <div class="nav-item" onclick="showSection('content-review-video')">🎥 State Review Video</div>
        <div class="nav-item" onclick="showSection('content-ready-photo')">📸 State Ready Photo</div>
        <div class="nav-item" onclick="showSection('content-review-final')">🏁 State Review Final</div>
        <div class="nav-item" onclick="showSection('content-success')">🎉 State Success</div>
        <div class="nav-item" onclick="showSection('content-side-panel')">📐 Side Panel Overlays</div>
        <div class="nav-item" onclick="showSection('content-result')">📱 Guest Result Page</div>

        <div class="nav-line"></div>
        <div class="nav-item" onclick="showSection('media')">🎬 Media Assets</div>
        <div class="nav-item" onclick="showSection('delivery')">📨 Delivery System</div>
        <div class="nav-item" onclick="showSection('system')">⚙️ Core Settings</div>
        <div class="nav-item" onclick="showSection('sessions')">📊 Sessions &amp; Gallery</div>
    </div>

    <div class="main-view">
        <div id="event-badge" style="background: rgba(211, 187, 124, 0.1); border: 1px solid var(--border); padding: 12px 20px; border-radius: 10px; margin-bottom: 20px; font-size: 13px; color: var(--accent); display: flex; align-items: center; justify-content: space-between;">
            <span>Editing Event: <strong id="active-event-name">audric-cathrine</strong></span>
            <span style="font-size: 11px; opacity: 0.8;">Pass <code>?event=slug</code> in the URL to edit a different event</span>
        </div>

        <!-- SECTION: VISUALS -->
        <div id="section-visuals" class="view-section active">
            <h2>Screen Visual Theme</h2>

            <!-- Master Color Picker -->
            <div class="card">
                <label>🎨 Quick Theme Color (Global Color Applicator)</label>
                <small style="color:var(--text-muted); display:block; margin-bottom:15px;">
                    Choose a color to set all text, buttons, titles, and accent colors simultaneously in one click.
                </small>
                <div style="display: flex; align-items: center; gap: 15px;">
                    <input type="color" id="masterColorPicker" value="#D3BB7C" style="width: 50px; height: 40px; padding: 2px; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; cursor: pointer; background: transparent;">
                    <button type="button" class="btn-primary" onclick="applyMasterColor()" style="padding: 10px 20px; font-size: 13px; border-radius: 6px; min-width: auto; height: 40px;">Apply to All Text Fields</button>
                    <span id="masterApplyStatus" style="color: var(--accent); font-size: 12px; font-weight: 700; transition: opacity 0.5s;"></span>
                </div>
            </div>

            <div class="card">
                <label>Quick Theme Presets</label>
                <small style="color:var(--text-muted); display:block; margin-bottom:15px;">Select one of these themes to change all colors automatically.</small>
                <div class="preset-grid">
                    <div class="preset-card active" id="preset-gold" onclick="applyPreset('gold')">
                        <span class="preset-icon">👑</span>
                        <strong>Luxury Gold</strong>
                    </div>
                    <div class="preset-card" id="preset-romantic" onclick="applyPreset('romantic')">
                        <span class="preset-icon">🌸</span>
                        <strong>Pink Romance</strong>
                    </div>
                    <div class="preset-card" id="preset-monochrome" onclick="applyPreset('monochrome')">
                        <span class="preset-icon">♟️</span>
                        <strong>Monochrome Noir</strong>
                    </div>
                    <div class="preset-card" id="preset-rustic" onclick="applyPreset('rustic')">
                        <span class="preset-icon">🍂</span>
                        <strong>Rustic Wood</strong>
                    </div>
                </div>
            </div>

            <div class="grid-2">
                <div class="card">
                    <label>🎨 Background &amp; Accent Colors</label>
                    <small style="color:var(--text-muted); display:block; margin-bottom:15px;">
                        Set background (gradient), accent, and frame colors.
                    </small>
                    <div class="grid-2">
                        <div class="input-group">
                            <label>Background Gradient Start</label>
                            <div class="color-row" style="padding: 6px 10px;">
                                <input type="color" id="bgColor1">
                            </div>
                        </div>
                        <div class="input-group">
                            <label>Background Gradient End</label>
                            <div class="color-row" style="padding: 6px 10px;">
                                <input type="color" id="bgColor2">
                            </div>
                        </div>
                        <div class="input-group" style="margin-top: 10px;">
                            <label>Accent Color</label>
                            <div class="color-row" style="padding: 6px 10px;">
                                <input type="color" id="accentColor">
                            </div>
                        </div>
                        <div class="input-group" style="margin-top: 10px;">
                            <label>Frame Line</label>
                            <div class="color-row" style="padding: 6px 10px;">
                                <input type="color" id="frameColor">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <label>Font Style (Typography)</label>
                    <div class="input-group">
                        <select id="fontSelector" onchange="updateFontHidden()">
                            <option value="luxury">Luxury Script (ScribbleBooth Default)</option>
                            <option value="elegant">Elegant Serif (Playfair Display)</option>
                            <option value="modern">Modern Minimalist (Montserrat)</option>
                            <option value="classic">Classic Wedding (Cinzel)</option>
                            <option value="romantic">Romantic (Great Vibes)</option>
                            <option value="custom">Custom / Upload Font</option>
                        </select>
                        <small style="color:var(--text-muted); display:block; margin-top:8px;">Font will be automatically applied to Title and Text without setting a special URL.</small>
                    </div>

                    <div id="custom-font-fields" style="display: none; margin-top: 15px; border-top: 1px dashed rgba(255,255,255,0.1); padding-top: 15px;">
                        <div class="input-group" style="margin-bottom: 15px;">
                            <label>Font Source</label>
                            <div class="radio-group" style="margin-top: 5px;">
                                <div class="radio-item">
                                    <input type="radio" name="fontSourceType" id="font-source-google" value="google" checked onchange="toggleFontSourceFields()">
                                    <label for="font-source-google">🌐 Google Fonts / CSS Link</label>
                                </div>
                                <div class="radio-item">
                                    <input type="radio" name="fontSourceType" id="font-source-upload" value="upload" onchange="toggleFontSourceFields()">
                                    <label for="font-source-upload">📤 Upload File Font (.ttf, .otf, .woff, .woff2)</label>
                                </div>
                            </div>
                        </div>

                        <!-- Google Font fields -->
                        <div id="font-google-container" class="input-group">
                            <label>Google Fonts URL / Font CSS URL</label>
                            <input type="text" id="fontUrl" placeholder="e.g.: https://fonts.googleapis.com/css2?family=Roboto&display=swap">
                            <small style="color:var(--text-muted); display:block; margin-top:5px;">Enter Google Fonts stylesheet URL.</small>
                        </div>

                        <!-- Local Font upload fields -->
                        <div id="font-upload-container" class="input-group" style="display: none;">
                            <label>Upload File Font (.ttf, .otf, .woff, .woff2)</label>
                            <div class="upload-box" style="margin-top: 5px; padding: 15px; background: rgba(255,255,255,0.02); border: 1px dashed var(--border); border-radius: 8px;">
                                <small id="fontFileStatus" style="color:var(--accent); font-size:10px; display:block; margin-bottom:10px;">No file uploaded yet</small>
                                <input type="file" id="fontFile" accept=".ttf,.otf,.woff,.woff2" style="font-size:11px; margin-bottom: 10px;">
                                <div class="btn-browse" onclick="openLibrary('fontUrl', 'fontFileStatus')" style="display: inline-block;">📁 Choose from Asset Library</div>
                            </div>
                        </div>

                        <div class="grid-2" style="margin-top: 15px;">
                            <div class="input-group">
                                <label>Font Family (Regular Text)</label>
                                <input type="text" id="fontFamily" placeholder="e.g. 'Roboto', sans-serif">
                            </div>
                            <div class="input-group">
                                <label>Font Family (Main Title)</label>
                                <input type="text" id="titleFontFamily" placeholder="e.g. 'Luxurious Script', cursive">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

